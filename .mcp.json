{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "glif": {
      "command": "npx",
      "args": [
        "@glifxyz/glif-mcp-server"
      ],
      "env": {
        "GLIF_API_TOKEN": "${GLIF_API_TOKEN}"
      }
    }
  }
}
